{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Portfolio Profile Schema",
  "description": "Schema for validating portfolio profile initialization data",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "description": "Metadata about the profile",
      "properties": {
        "owner": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "personalInfo": {
      "type": "object",
      "description": "Personal information of the portfolio owner",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "title": {
          "type": "string",
          "maxLength": 100
        },
        "subtitle": {
          "type": "string"
        },
        "tagline": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "currentLocation": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "university": {
          "type": "string"
        },
        "course": {
          "type": "string"
        },
        "availability": {
          "type": "string"
        },
        "workMode": {
          "type": "string"
        },
        "bio": {
          "type": "object",
          "properties": {
            "intro": { "type": "string" },
            "full": { "type": "string" },
            "robotics": { "type": "string" },
            "interests": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "required": [
        "name",
        "email"
      ],
      "additionalProperties": false
    },
    "careerPreferences": {
      "type": "object",
      "properties": {
        "targetRoles": { "type": "array", "items": { "type": "string" } },
        "jobTypes": { "type": "array", "items": { "type": "string" } },
        "preferredDomains": { "type": "array", "items": { "type": "string" } },
        "workModePreferences": { "type": "array", "items": { "type": "string" } },
        "openToRelocation": { "type": "boolean" },
        "preferredLocations": { "type": "array", "items": { "type": "string" } },
        "availability": { "type": "string" },
        "noticePeriod": { "type": "string" }
      },
      "additionalProperties": true
    },
    "socialLinks": {
      "type": "object",
      "properties": {
        "github": { "type": "string", "format": "uri" },
        "linkedin": { "type": "string", "format": "uri" },
        "leetcode": { "type": "string", "format": "uri" },
        "geeksforgeeks": { "type": "string", "format": "uri" },
        "codechef": { "type": "string", "format": "uri" },
        "codeforces": { "type": "string", "format": "uri" },
        "twitter": { "type": "string", "format": "uri" },
        "instagram": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["id", "name"]
      }
    },
    "achievements": {
      "type": "object",
      "properties": {
        "competitiveProgramming": {
          "type": "object",
          "properties": {
            "leetcode": {
              "type": "object",
              "properties": {
                "rating": { "type": "string" },
                "maxRating": { "type": "string" },
                "problemsSolved": { "type": "string" },
                "globalRanking": { "type": "string" },
                "percentile": { "type": "string" }
              }
            },
            "codechef": {
              "type": "object",
              "properties": {
                "rating": { "type": "string" },
                "maxRating": { "type": "string" },
                "problemsSolved": { "type": "string" },
                "stars": { "type": "string" },
                "division": { "type": "string" }
              }
            },
            "codeforces": {
              "type": "object",
              "properties": {
                "rating": { "type": "string" },
                "maxRating": { "type": "string" },
                "problemsSolved": { "type": "string" },
                "rank": { "type": "string" }
              }
            },
            "geeksforgeeks": {
              "type": "object",
              "properties": {
                "problemsSolved": { "type": "string" },
                "rank": { "type": "string" }
              }
            }
          }
        },
        "overallStats": {
          "type": "object",
          "properties": {
            "yearsExperience": { "type": "string" },
            "commits": { "type": "string" },
            "totalProblemsSolved": { "type": "string" }
          }
        },
        "awards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "year": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["title"]
          }
        }
      },
      "additionalProperties": true
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "issuer": { "type": "string" },
          "year": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["title", "issuer"]
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": { "type": "string" },
          "degree": { "type": "string" },
          "institution": { "type": "string" },
          "location": { "type": "string" },
          "duration": { "type": "string" },
          "status": { "type": "string" },
          "cgpa": { "type": "string" },
          "percentage": { "type": "string" },
          "courses": { "type": "array", "items": { "type": "string" } },
          "activities": { "type": "array", "items": { "type": "string" } },
          "achievements": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["institution", "degree"]
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string" },
          "organization": { "type": "string" },
          "location": { "type": "string" },
          "period": { "type": "string" },
          "description": { "type": "string" },
          "skills": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["role", "organization"]
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "techStack": { "type": "array", "items": { "type": "string" } },
          "features": { "type": "array", "items": { "type": "string" } },
          "links": {
            "type": "object",
            "properties": {
              "live": { "type": "string", "format": "uri" },
              "github": { "type": "string", "format": "uri" }
            }
          },
          "status": { "type": "string" }
        },
        "required": ["name", "description"]
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "currentFocus": {
      "type": "object",
      "properties": {
        "learning": { "type": "string" },
        "building": { "type": "string" },
        "lookingFor": { "type": "string" }
      }
    }
  },
  "required": [
    "meta",
    "personalInfo"
  ],
  "additionalProperties": true
}