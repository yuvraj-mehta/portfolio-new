# Server Configuration
PORT=3500
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/portfolio

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# If using Google Gemini (default)
# You can provide multiple keys separated by commas for rate-limit rotation
GEMINI_API_KEYS=your_first_gemini_api_key_here,your_second_gemini_api_key_here

# Qdrant Vector Database Configuration
QDRANT_URL=http://localhost:6333

# GenAI Flexible Provider Configuration
GENAI_PROVIDER=openai

# Optional overrides:
# EMBEDDING_MODEL=text-embedding-3-large
# CHAT_MODEL=gpt-4o-mini
